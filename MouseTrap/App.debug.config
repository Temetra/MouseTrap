<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<configSections>
		<sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" >
			<section name="MouseTrap.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
		</sectionGroup>
	</configSections>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
	<system.diagnostics>
		<trace autoflush="true" indentsize="4"></trace>
		<sources>
			<source name="MouseTrap" switchName="sourceSwitch" switchType="System.Diagnostics.SourceSwitch">
				<listeners>
					<add name="logfile" type="System.Diagnostics.DelimitedListTraceListener" initializeData="log.txt" traceOutputOptions="Timestamp" />
				</listeners>
			</source>
		</sources>
		<switches>
			<add name="sourceSwitch" value="Verbose" />
		</switches>
	</system.diagnostics>
	<userSettings>
		<MouseTrap.Properties.Settings>
			<setting name="AudioFeedbackGainedForeground" serializeAs="String">
				<value>Beep</value>
			</setting>
			<setting name="AudioFeedbackLostForeground" serializeAs="String">
				<value>Asterisk</value>
			</setting>
		</MouseTrap.Properties.Settings>
	</userSettings>
</configuration>