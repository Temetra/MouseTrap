<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup> 
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
	<system.diagnostics>
		<trace autoflush="true" indentsize="4"></trace>
		<sources>
			<source name="MouseTrap" switchName="sourceSwitch" switchType="System.Diagnostics.SourceSwitch">
				<listeners>
					<add name="logfile" type="System.Diagnostics.DelimitedListTraceListener" initializeData="log.txt" traceOutputOptions="Timestamp" />
				</listeners>
			</source>
		</sources>
		<switches>
			<add name="sourceSwitch" value="Verbose" />
		</switches>
	</system.diagnostics>
</configuration>