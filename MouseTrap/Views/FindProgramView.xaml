<UserControl x:Class="MouseTrap.Views.FindProgramView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
	xmlns:design="clr-namespace:MouseTrap.DesignTime"
	xmlns:controls="clr-namespace:MouseTrap.Controls"
	mc:Ignorable="d" 
	Background="{DynamicResource Main.Background}"
	d:DataContext="{d:DesignInstance design:FindProgram, IsDesignTimeCreatable=True}" 
	d:DesignHeight="300" d:DesignWidth="478">
	<UserControl.Resources>
		<ResourceDictionary>
			<Style TargetType="{x:Type controls:BarButtonControl}">
				<Setter Property="ImageMargin" Value="0,8" />
				<Setter Property="BorderThickness" Value="1" />
				<Setter Property="Background" Value="#FFDDDDDD" />
				<Setter Property="BorderBrush" Value="#FF707070" />
				<Setter Property="HoverBackground" Value="#FFBEE6FD" />
				<Setter Property="HoverBorder" Value="#FF3C7FB1" />
				<Setter Property="PressedBackground" Value="#FFC4E5F6" />
				<Setter Property="PressedBorder" Value="#FF2C628B" />
				<Setter Property="DisabledForeground" Value="#FFF4F4F4" />
				<Setter Property="DisabledBackground" Value="#FFADB2B5" />
				<Setter Property="DisabledBorder" Value="#FF838383" />
			</Style>
		</ResourceDictionary>
	</UserControl.Resources>

	<Grid Margin="8">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="38" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="38"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<TextBlock Margin="0,0,0,8">
			Find a program to lock:
		</TextBlock>

		<TextBox Grid.Row="1" Grid.Column="0" 
				Width="Auto" Padding="4,0" Margin="0,0,8,0" 
				FontSize="14" VerticalContentAlignment="Center" 
				Text="{Binding Filename, UpdateSourceTrigger=PropertyChanged}" 
				PreviewDragOver="TextBox_PreviewDragOver"
				PreviewDragEnter="TextBox_PreviewDragOver"
				PreviewDrop="TextBox_PreviewDrop" />

		<controls:BarButtonControl Grid.Row="1" Grid.Column="1"
			Text="" ToolTip="Browse for program"
			Image="{StaticResource 1f4c2-open_file_folder}"
			Command="{Binding FindFileCommand}" />

		<TextBlock Grid.Row="2" Grid.ColumnSpan="2" 
				Margin="0,0,0,8" 
				FontSize="16" 
				VerticalAlignment="Center" 
				HorizontalAlignment="Center">
			<TextBlock.Style>
				<Style TargetType="TextBlock">
					<Setter Property="Text" Value="❎ Program not found" />
					<Style.Triggers>
						<DataTrigger Binding="{Binding IsFilenameValid}" Value="True">
							<Setter Property="FontSize" Value="16" />
							<Setter Property="Text" Value="✅ Program found" />
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</TextBlock.Style>
		</TextBlock>

	</Grid>
</UserControl>
