<Window x:Class="MouseTrap.Views.ErrorWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	Title="Error - Mouse Trap" Height="200" Width="300" WindowStartupLocation="CenterScreen">
	<Grid Margin="16,8,16,16">
		<TextBlock FontSize="24">Error</TextBlock>
		<TextBlock FontSize="14" Margin="0,40,0,0" TextWrapping="Wrap">
			Oh no! Something went terribly wrong. Let me know what happened at 
			<Hyperlink NavigateUri="https://github.com/Temetra/MouseTrap/issues" RequestNavigate="Hyperlink_RequestNavigate">GitHub</Hyperlink>.
		</TextBlock>
		<Button Width="128" Height="32" HorizontalAlignment="Center" VerticalAlignment="Bottom" Click="Button_Click">Close Program</Button>
	</Grid>
</Window>
