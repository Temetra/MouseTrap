<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<SolidColorBrush x:Key="Border" Color="Black"/>
	<SolidColorBrush x:Key="Foreground" Color="#FFFEBD38"/>
	<SolidColorBrush x:Key="Background" Color="White"/>
	<DrawingImage x:Key="Shield">
		<DrawingImage.Drawing>
			<DrawingGroup>
				<GeometryDrawing Brush="Transparent">
					<GeometryDrawing.Geometry>
						<GeometryGroup>
							<RectangleGeometry Rect="0,0,64,64"/>
						</GeometryGroup>
					</GeometryDrawing.Geometry>
				</GeometryDrawing>
				<GeometryDrawing Brush="{StaticResource Background}" Geometry="M 32,4 C 23,4 21,11 7.963615,11 L 8,26 C 8,44 32,60 32,60 32,60 56,44 56,26 V 11 C 42.964859,11 41,4 32,4 Z" />
				<GeometryDrawing Brush="{StaticResource Foreground}" Geometry="m 32,4 v 28 h 23 c 0.543362,-1.985728 0.925012,-4.019382 0.934143,-6.086957 L 56,11 C 42.964859,11 40.690094,4 32,4 Z" />
				<GeometryDrawing Brush="{StaticResource Foreground}" Geometry="m 9,32 c 4.255567,15.552106 23,28 23,28 V 32 Z" />
				<GeometryDrawing Geometry="M 32,4 C 23,4 21,11 7.963615,11 L 8,26 C 8,44 32,60 32,60 32,60 56,44 56,26 V 11 C 42.964859,11 41,4 32,4 Z">
					<GeometryDrawing.Pen>
						<Pen Thickness="2" Brush="{StaticResource Border}" LineJoin="Bevel" StartLineCap="Round" EndLineCap="Round" />
					</GeometryDrawing.Pen>
				</GeometryDrawing>
			</DrawingGroup>
		</DrawingImage.Drawing>
	</DrawingImage>
</ResourceDictionary>