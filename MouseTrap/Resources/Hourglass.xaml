			<DrawingGroup>
				<GeometryDrawing Brush="Transparent">
					<GeometryDrawing.Geometry>
						<GeometryGroup>
							<RectangleGeometry Rect="0,0,64,64"/>
						</GeometryGroup>
					</GeometryDrawing.Geometry>
				</GeometryDrawing>
				<GeometryDrawing Brush="{StaticResource Background}" Geometry="m 12,4 c -2,0 -2,4 0,4 h 1 c 0,16 12,16 12,24 0,8 -12,8 -12,24 h -1 c -2,0 -2,4 0,4 13.333333,0 26.666667,0 40,0 2,0 2,-4 0,-4 H 51 C 51,40 39,40 39,32 39,24 51,24 51,8 h 1 C 54,8 54,4 52,4 38.666667,4 25.333333,4 12,4 Z">
					<GeometryDrawing.Pen>
						<Pen Brush="{StaticResource Border}" Thickness="2" />
					</GeometryDrawing.Pen>
				</GeometryDrawing>
				<GeometryDrawing Brush="{StaticResource Foreground}" Geometry="M 20,55.5 C 20,40.5 31,42 31,32 31,22 20,20 20,16 h 24 c 0,4 -11,6 -11,16 0,10 11,8.5 11,23.5 z" />
			</DrawingGroup>
		</DrawingImage.Drawing>
	</DrawingImage>
</ResourceDictionary>